<?xml version="1.0" encoding="UTF-8"?>
<!--
  Build chạy trong CI hay gặp Maven Central (repo.maven.apache.org) trả 403/limit.
  Định tuyến mọi request "central" qua mirror Google GCS (read-only, ổn định) để
  tránh 403 và tăng độ tin cậy khi build image.
-->
<settings xmlns="http://maven.apache.org/SETTINGS/1.0.0">
  <mirrors>
    <mirror>
      <id>google-maven-central</id>
      <name>Google GCS mirror of Maven Central</name>
      <url>https://maven-central.storage-download.googleapis.com/maven2/</url>
      <mirrorOf>central</mirrorOf>
    </mirror>
  </mirrors>
</settings>
